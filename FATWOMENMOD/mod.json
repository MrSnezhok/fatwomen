{
    "geode": "v3.0.0",
    "id": "mr.snezhok.fatwomen",
    "name": "FatWomen",
    "version": "v1.0.0",
    "developer": "MrSnezhok",
    "description": "Mod with image and click counter",
    "binary": "fatwomen.geode",
    "resources": {
        "files": [
            "resources/*.png"
        ]
    },
    "settings": {
        "position-x": {
            "name": "Image X Position",
